# Unity 6 - .gitignore
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Uu]ser[Ss]ettings/

# MemoryCaptures (có thể có tệp dump lớn)
/[Mm]emoryCaptures/

# AssetStore cache
/[Aa]ssets/[Aa]ssetStoreTools/

# Autogenerated VS/MD solution and project files
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Unity3D generated meta files
*.pidb.meta
*.pdb.meta
*.mdb.meta

# Unity3D VCS cache
/[Aa]ssets/Plugins/Editor/JetBrains*

# OS specific junk
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
[Tt]humbs.db
[Dd]esktop.ini

# Unity generated folder for IL2CPP
/[Aa]utomaticGraph/