<ui:UXML xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" noNamespaceSchemaLocation="../../UIElementsSchema/UIElements.xsd" editor-extension-mode="False">
    <ui:VisualElement name="VisualElement" style="flex-grow: 1; align-self: auto; align-content: auto; align-items: auto; background-color: rgba(0, 0, 0, 0.2); border-top-left-radius: 50px; border-top-right-radius: 50px; border-bottom-right-radius: 50px; border-bottom-left-radius: 50px; margin-bottom: 0; margin-top: -40px;">
        <ui:Button text="Start Game" name="start" style="color: rgb(255, 255, 255); align-self: center; -unity-text-outline-color: rgb(0, 0, 0); -unity-text-outline-width: 1px; font-size: 24px; -unity-font-style: bold; background-color: rgb(20, 217, 0); align-items: auto; justify-content: flex-start; align-content: auto; border-top-left-radius: 10px; border-top-right-radius: 10px; border-bottom-right-radius: 10px; border-bottom-left-radius: 10px; border-bottom-width: 1px; bottom: -100px;" />
        <ui:Button text=" setting&#10;(i dont have time to make this)" name="setting" style="color: rgb(255, 255, 255); align-self: center; -unity-text-outline-color: rgb(0, 0, 0); -unity-text-outline-width: 1px; font-size: 24px; -unity-font-style: bold; background-color: rgb(231, 255, 0); align-content: auto; align-items: center; -unity-text-align: lower-center; border-top-left-radius: 15px; border-top-right-radius: 15px; border-bottom-right-radius: 15px; border-bottom-left-radius: 15px; bottom: -100px;" />
        <ui:Button text="Why you want to quit&#10;your mission ?" name="quit" style="color: rgb(255, 255, 255); align-self: center; -unity-text-outline-color: rgb(0, 0, 0); -unity-text-outline-width: 1px; font-size: 24px; -unity-font-style: bold; background-color: rgb(255, 27, 0); padding-bottom: 12px; margin-bottom: 2px; top: auto; bottom: -100px; position: relative; -unity-text-align: upper-center; border-top-left-radius: 10px; border-top-right-radius: 10px; border-bottom-right-radius: 10px; border-bottom-left-radius: 10px;" />
        <ui:Button text="Campain" name="Map" style="color: rgb(255, 255, 255); align-self: center; -unity-text-outline-color: rgb(0, 0, 0); -unity-text-outline-width: 1px; font-size: 24px; -unity-font-style: bold; background-color: rgb(217, 153, 0); align-items: auto; justify-content: flex-start; align-content: auto; border-top-left-radius: 10px; border-top-right-radius: 10px; border-bottom-right-radius: 10px; border-bottom-left-radius: 10px; border-bottom-width: 1px; bottom: -100px;" />
    </ui:VisualElement>
</ui:UXML>
